@{
    ViewData["Title"] = "Music Store";
}

<h2>Music Store</h2>

<div class="toolbar">
    <div class="toolbar-group">
        <label for="region">Region</label>
        <select id="region">
            <option value="en-US">English (US)</option>
            <option value="de-DE">German (DE)</option>
        </select>
    </div>

    <div class="toolbar-group">
        <label for="seed">Seed</label>
        <input type="number" id="seed" value="12345" />
    </div>

    <div class="toolbar-group">
        <label>&nbsp;</label>
        <button id="randomSeedBtn" type="button">Random Seed</button>
    </div>

    <div class="toolbar-group">
        <label for="likes">Likes</label>
        <input type="number" id="likes" value="3.5" step="0.1" min="0" max="10" />
    </div>

    <div class="toolbar-group">
        <label for="viewMode">View</label>
        <select id="viewMode">
            <option value="table">Table</option>
            <option value="gallery">Gallery</option>
        </select>
    </div>
</div>

<div id="loading">Loading...</div>

<div id="tableContainer">
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Artist</th>
                    <th>Album</th>
                    <th>Genre</th>
                    <th>Likes</th>
                </tr>
            </thead>
            <tbody id="songTableBody"></tbody>
        </table>
    </div>

    <div class="pagination-bar">
        <button id="prevBtn" type="button">Previous</button>
        <span>Page: <span id="pageNumber">1</span></span>
        <button id="nextBtn" type="button">Next</button>
    </div>
</div>

<div id="galleryContainer" style="display:none;">
    <div id="galleryGrid"></div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>